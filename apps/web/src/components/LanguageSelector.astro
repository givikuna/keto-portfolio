---
const { currentLang } = Astro.props as { currentLang: string };

const langs: [string, string, string] = ["en", "ru", "ka"];
const labels: Record<string, string> = { en: "EN", ru: "RU", ka: "KA" };
const basePath: string = Astro.url.pathname.replace(/^\/[a-z]{2}/, "") || "/";
---

<nav class="lang-selector">
    {
        langs.map((lang) => (
            <a
                href={`/${lang}${basePath === "/" ? "" : basePath}`}
                class={lang === currentLang ? "active" : ""}
            >
                {labels[lang]}
            </a>
        ))
    }
</nav>
