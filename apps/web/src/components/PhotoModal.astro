---
// const { lang } = Astro.props as { lang: string };
---

<div
    id="photo-modal"
    class="modal hidden"
    onclick="closeModal(event)"
>
    <div
        class="modal-content"
        onclick="event.stopPropagation()"
    >
        <span
            class="close-btn"
            onclick="closeModal()"
        >
            &times;
        </span>
        <img
            id="modal-img"
            src=""
            alt=""
        />
        <p id="modal-desc"></p>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", (): void => {
        const modal: HTMLElement = document.getElementById("photo-modal")!;
        const modalImg: HTMLImageElement = document.getElementById("modal-img") as HTMLImageElement;
        const modalDesc: HTMLElement = document.getElementById("modal-desc")!;

        document.querySelectorAll(".masonry-img").forEach((img: Element) => {
            img.addEventListener("click", (_e: Event): void => {
                modalImg.src = img.getAttribute("src")!;
                modalDesc.textContent =
                    ((img.closest(".masonry-item") as HTMLElement).dataset[
                        "description"
                    ] as string) || "";
                modal.classList.remove("hidden");
                document.body.style.overflow = "hidden";
            });
        });
    });

    (window as any).closeModal = (_e): void => {
        document.getElementById("photo-modal")?.classList.add("hidden");
        document.body.style.overflow = "";
    };
</script>

<style>
    .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.8);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        backdrop-filter: blur(4px);
    }
    .modal.hidden {
        display: none;
    }
    .modal-content {
        background: white;
        padding: 1.5rem;
        border-radius: 16px;
        max-width: 80%;
        max-height: 90%;
        position: relative;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }
    .modal-content img {
        max-width: 100%;
        max-height: 70vh;
        border-radius: 8px;
    }
    .close-btn {
        position: absolute;
        top: 0.5rem;
        right: 1rem;
        font-size: 2rem;
        cursor: pointer;
        color: #333;
    }
    #modal-desc {
        margin-top: 0.5rem;
        text-align: center;
        font-style: italic;
    }
</style>
